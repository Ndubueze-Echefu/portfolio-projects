;---------------------------------------------------------------------------
; Throw - Attempt
[Statedef 800]
type    = S
movetype= A
physics = S
juggle  = 0
velset = 0,0
ctrl = 0
anim = 800

; Notes: The '-' symbol in the hitflag field means that it only affects
;   players who are not in a hit state. This prevents the player from combo-ing
;   into the throw. The priority should be set to a low number, such as
;   1 or 2, so that the throw does not take precedence over normal attacks.
;   The type of priority must always be set to "Miss" or "Dodge" for throws,
;   otherwise strange behavior can result.
[State 800, Hitbox for grabbing]
type = HitDef
Trigger1 = Time = 0
attr = S, NT          ;Attributes: Standing, Normal Throw
hitflag = M-          ;Affect only ground people who are not being hit
priority = 1, Miss    ;Throw has low priority, must be miss or dodge type.
sparkno = -1          ;No spark
sprpriority = 1       ;Draw in front of p2
p1facing = ifelse (command = "holdfwd", -1, 1) ;Turn if holding forwards
p2facing = 1          ;Force p2 to face player
p1stateno = 810       ;On success, player changes to state 810
p2stateno = 820       ;If hit, p2 changes to state 820 in player's cns
fall = 1              ;Force p2 into falling down
hitsound = s8, 0

[State 800, Change back to Idle state if fail]
type = ChangeState
Trigger1 = AnimTime = 0
value = 0
ctrl = 1

;---------------------------------------------------------------------------
; Throwing the opponent
[Statedef 810]
type    = S
movetype= A
physics = N
anim = 810
poweradd = 60

[State 810, Swing Opponent to the right!]
type = TargetBind
trigger1 = time > 0 && time < 32
trigger1 = timemod = 16,0
time = 8
pos = 60, 0

[State 810, Swing Opponent to the left!]
type = TargetBind
trigger1 = time > 0 && time < 32
trigger1 = timemod = 16,8
time = 8
pos = -60, 0

[State 810, Adjust Width]
type = Width
trigger1 = AnimElem = 2
edge = 60,0

[State 810, Take 60 HP after throwing opponent]
type = TargetLifeAdd
trigger1 = AnimElem = 9
value = -60

[State 810, Force to face the RIGHT way after throwing]
type = Turn
trigger1 = AnimElem = 9

[State 810, Go back to Idle State]
type = ChangeState
trigger1 = AnimTime = 0
value = 0
ctrl = 1

[State 810, Swinging Sounds]
type = PlaySnd
trigger1 = timemod = 8,0 && time < 32
value = S0,5

[State 810, Last Throw Sound]
type = PlaySnd
trigger1 = Animelem = 9
value = S0,6


