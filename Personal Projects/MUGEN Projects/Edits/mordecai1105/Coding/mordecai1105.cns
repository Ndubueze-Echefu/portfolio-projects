;---------------------------------------------------------------------------
; Introduction: "OHH!"
[Statedef 190]
type = S
ctrl = 0
anim = 190
velset = 0,0

[State -1, Ayo, Rigby's here?! Bet!]
type = ChangeState
trigger1 = p2name = "Rigby1105" || p4name = "Rigby1105"
trigger1 = time = 0
value = 193
ctrl = 0

[State -1, Rigby is not my friend >:(]
type = ChangeState
triggerall = p3name != "Rigby1105"
trigger1 = time = 0
trigger1 = random > 500
value = 191
ctrl = 0

[State -1, He's not mine either >:(]
type = ChangeState
triggerall = p3name != "Rigby1105"
trigger1 = time = 0
trigger1 = random > 500
value = 192
ctrl = 0

[State 190, Freeze animation until PreIntro is over]
type = ChangeAnim
trigger1 = RoundState = 0
value = 190

[State 190, Intro - Assert this until you want "round 1, fight" to begin]
type = AssertSpecial
trigger1 = anim = 190
flag = Intro

[State 190, Empty GUI - Assert this until you want "round 1, fight" to begin]
type = AssertSpecial
trigger1 = 1
flag = nobardisplay

[State 190, No Music - Assert this until you want "round 1, fight" to begin]
type = AssertSpecial
trigger1 = roundno = 1
flag = nomusic

[State 190, "OHHHHHHHHH!"]
type = PlaySnd
trigger1 = time = 0
value = S2,5
channel = 1

[State 190, Stop sound once animtime becomes zero]
type = StopSnd
trigger1 = animtime = 0
channel = 1

[State 190, Change to stand state]
type = ChangeAnim
trigger1 = animtime = 0
value = 0

