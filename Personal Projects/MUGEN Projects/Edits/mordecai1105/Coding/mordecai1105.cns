[StateDef 30000]   
type = A
movetype = H
physics = N
anim = 30000
velset = 5,-20

[State 30000, VelMul]
type = Gravity
trigger1 = 1

[State 0, DestroySelf]
type = DestroySelf
trigger1 = roundstate = 2
;---------------------------------------------------------------------------
; Override common states (use same number to override) :
;---------------------------------------------------------------------------

;---------------------------------------------------------------------------
; States that are always executed (use statedef -2)
;---------------------------------------------------------------------------

[Statedef -2]

[State -2]
type = Helper
trigger1 = roundstate = 3
trigger1 = numhelper(8000) = 0
helpertype = normal
ID = 8000
stateno = 8000
pos = 0,-20
postype = back
ownpal = 1
size.shadowoffset = -12

;---------------------------------------------------------------------------
; States that are executed when in self's state file (use statedef -3)
;---------------------------------------------------------------------------

[Statedef -3]

[State -3]
type = AssertSpecial
trigger1 = roundstate != 2
flag = nobardisplay
ignorehitpause = 1

[State -3]
type = RemoveExplod
trigger1 = stateno != 6000
trigger1 = stateno != 6001
trigger1 = stateno != 6002
trigger1 = stateno != 6003
trigger1 = numhelper(10000) = 0
id = 700
ignorehitpause = 1
