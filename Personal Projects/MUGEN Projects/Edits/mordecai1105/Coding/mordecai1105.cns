trigger1 = animtime = 0
value = 5050


;---------------------------------------------------------------------------
; Hyper finish
[Statedef 8000]
type    = S
movetype = I
physics = N
anim = 8000

[State 8000, 0]
type = Pause
trigger1 = time = 1
time = 15
movetime = 15

[State 8000, 1]
type = BGPalFX
trigger1 = time = 1
time = 15
add = 0,0,0
mul = 256,256,256
sinadd = 0,0,0,1
invertall = 1
color = 256
ignorehitpause = 1
