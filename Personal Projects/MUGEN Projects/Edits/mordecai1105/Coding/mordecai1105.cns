; Constants and state file.
; There are comments scattered through this file, so you may like to
; take a look if would like to learn more about the cns.

; Notes:
; - Any states with the 🚩 emoji, unfinished and needs attention
; - Don't forget to revamp the cmd files as well. This character has 3 cmd versions: the main one, the brutal AI one, and the serious AI one. Only focus on the main one. You're gonna revamp the AI anyways. 🤷‍
;-------------------------------------------------------------------------------------------------------------
[Data]
life = 1000			;Amount of life to start with
power = 5000		;Amount of maximum power
attack = 100		;attack power (more is stronger)
defence = 100		;defensive power (more is stronger)
fall.defence_up = 50	;Percentage to increase defense everytime player is knocked down
liedown.time = 60		;Time which player lies down for, before getting up
airjuggle = 15		;Number of points for juggling
sparkno = 2			;Default hit spark number for HitDefs
guard.sparkno = 40	;Default guard spark number
KO.echo = 0			;1 to enable echo on KO
volume = 0			;Volume offset (negative for softer)
IntPersistIndex = 60	;Variables with this index and above will not have their values
FloatPersistIndex = 40  ;reset to 0 between rounds or matches. There are 60 int variables,
  				;indexed from 0 to 59, and 40 float variables, indexed from 0 to 39.
  				;If omitted, then it defaults to 60 and 40 for integer and float
  				;variables repectively, meaning that none are persistent, i.e. all
  				;are reset. If you want your variables to persist between matches,
  				;you need to override state 5900 from common1.cns.


[Size]
xscale = 1			;Horizontal scaling factor.
yscale = 1			;Vertical scaling factor.
ground.back = 15		;Player width (back, ground)
ground.front = 16		;Player width (front, ground)
air.back = 12		;Player width (back, air)
air.front = 12		;Player width (front, air)
height = 60			;Height of player (for opponent to jump over)
attack.dist = 160		;Default attack distance
proj.attack.dist = 90	;Default attack distance for projectiles
proj.doscale = 0		;Set to 1 to scale projectiles too   
head.pos = -5, -90	;Approximate position of head
mid.pos = -5, -60		;Approximate position of midsection
shadowoffset = 0		;Number of pixels to vertically offset the shadow
draw.offset = 0,0		;Player drawing offset in pixels (x, y)

[Velocity]
walk.fwd  = 5		;Walk forward
walk.back = -5		;Walk backward
run.fwd  = 19,-7		;Run forward (x, y)
run.back = -19,-7	;Hop backward (x, y)
jump.neu = 0,-16		;Neutral jumping velocity (x, y)
jump.back = -7		;Jump back Speed (x, y)
jump.fwd = 7		;Jump forward Speed (x, y)
runjump.back = -2.55,-8.1;Running jump speeds (opt)
runjump.fwd = 4,-8.1	;.
airjump.neu = 0,-8.1	;.
airjump.back = -7	;Air jump speeds (opt)
airjump.fwd = 7		;.

[Movement]
airjump.num = 2		;Number of air jumps allowed (opt)
airjump.height = 35	;Minimum distance from ground before you can air jump (opt)
yaccel = .9		;Vertical acceleration
stand.friction = .85	;Friction coefficient when standing
crouch.friction = .82	;Friction coefficient when crouching

[Quotes]
victory1 = "Well, that was interesting."
victory2 = "WHOOOOOOOOOOOOOOOOOOOOOOOOAAA..."
victory3 = "Well, I gotta go. We shouldn't talk so much."
victory4 = "I spit in the face of that battle."
victory5 = "This IS just like Strong Johns!"
victory6 = "I'm pretty sure I pictured you as being taller."
victory7 = "I tire of whupping everything that moves!"
victory8 = "Landlocked mammals can't compete with Mad Man Mordo."
victory9 = "I will give you this: that was a spectacular match."
victory10 = "I wonder why I didn't fly by myself when I helped rescue those baby ducks."
victory11 = "For an odd match, that was... odd."

;---------------------------------------------------------------------------
; Format:
; [Statedef STATENO]
; type = ?      S/C/A/L  stand/crouch/air/liedown
; movetype = ?  I/A/H    idle/attack/gethit
; physics = ?   S/C/A/N  stand/crouch/air/none
; juggle = ?             air juggle points move requires
;
; [State STATENO, ?]     ? - any number you choose
; type = ?
; ...
;---------------------------------------------------------------------------

;---------------------------------------------------------------------------
;---------------------------------------------------------------------------
; Hi Jump Start
[Statedef 53]
type    = S
physics = S
anim = 40
ctrl = 0
sprpriority = 1
facep2 = 1

[State -3, Jumping Sound]
type = PlaySnd
trigger1 = animtime = 0
value = S0,6

[State 40, Set Jump Velocity]
type = VelSet
trigger1 = AnimTime = 0
y = -30

[State 40, Transistion to Actual Hi Jump]
type = ChangeState
trigger1 = AnimTime = 0
value = 54
ctrl = 1

;---------------------------------------------------------------------------
; Hi Jump
[Statedef 54]
type    = A
physics = A

[State 54, Create Jump Effect]
type = Explod
trigger1 = time = 0
anim = f62
pos = 0,0
postype = p1

[State 54, Increase Forward Velocity]
type = VelAdd
trigger1 = command = "holdfwd"
x = .5

[State 54, Increase Backward Velocity]
type = VelAdd
trigger1 = command = "holdback"
x = -.5

[State 54, Reset Variable]
type = VarSet
trigger1 = Time = 0
sysvar(1) = 0

[State 54, AfterEffects]
type = AfterImage
triggerall = !var(12)
trigger1 = Time = 0
time = 30
timegap = 1
framegap = 3
length = 15
palcontrast = 220,220,220
paladd = 10,10,10
palmul = .65,.65,.65
trans = add1

[State 54, Adjust Animation based on Velocity]
type = ChangeAnim
trigger1 = Time = 0
value = ifelse((vel x)=0, 41, ifelse((vel x)>0, 42, 43))

[State 54, Change Animation on Falling Down]
type = ChangeAnim
trigger1 = Vel y > Const720p(-8)
trigger1 = SelfAnimExist(anim + 3)
trigger1 = anim >= 41 && anim <= 43
persistent = 0
value = Anim + 3
;---------------------------------------------------------------------------
; Hop forward
[Statedef 100]
type    = A
physics = N
ctrl = 0
anim = 100
sprpriority = 1

[State 100, Dash Sound Effect]
type = PlaySnd
trigger1 = time = 0
value = S0,6

[State 100, Set Velocity Forward]
type = VelSet
trigger1 = time = 0
x = const(velocity.run.fwd.x)

[State 100, Grant Control]
type = CtrlSet
trigger1 = Time = 2
value = 1

[State 100, Change to Landing State]
type = ChangeState
trigger1 = time = 11
value = 52

[State 100, Dash Visual Effects]
type = Explod
trigger1 = timemod = 6,0
anim = f120
pos = 0,0
postype = p1

[State 100, AfterEffects]
type = AfterImage
triggerall = !var(12)
trigger1 = Time = 0
time = 11
timegap = 1
framegap = 3
length = 15
palcontrast = 220,220,220
paladd = 10,10,10
palmul = .65,.65,.65
trans = add1
